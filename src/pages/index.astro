---
import Layout from "../layouts/Layout.astro";
import { Content as IntroContent } from "../sections/intro.md";
import { Content as PersonalContent } from "../sections/personal.md";
import { Content as WritingContent } from "../sections/writing.md";
import { Content as OpenSourceContent } from "../sections/opensource.md";
import { Content as SupportContent } from "../sections/support.md";
import { formatDate, getBlogPosts, getPostSlug } from "../lib/blog";

const posts = await getBlogPosts();
const recentPosts = posts.slice(0, 5);
---

<Layout
  title="Timothy Brits"
  description="Links and ways to connect with Timothy Brits - social profiles, and more."
  type="website"
>
  <main id="main-content" tabindex="-1">
    <h1 class="visually-hidden">Timothy Brits</h1>
    <IntroContent />
    {
      recentPosts.length > 0 && (
        <div
          class="section-colored"
          style="--section-color: var(--color-apple-green-text); --section-border: var(--color-apple-green); --section-tint: var(--color-apple-green-tint); --section-hover: var(--color-apple-green-hover);"
        >
          <h2>Blog</h2>
          <ul class="recent-posts">
            {recentPosts.map((post) => (
              <li>
                <a href={`/blog/${getPostSlug(post.id)}`}>{post.data.title}</a>
                <time
                  class="post-date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {formatDate(post.data.pubDate)}
                </time>
              </li>
            ))}
          </ul>
          <a href="/blog" class="all-posts">
            All posts <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      )
    }
    <OpenSourceContent />
    <WritingContent />
    <SupportContent />
    <PersonalContent />
  </main>
</Layout>

<style>
  main {
    margin: auto;
  }

  :global(main > p:first-child) {
    color: var(--label);
    margin-bottom: 2.5rem;
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  :global(.section-colored) {
    margin-top: 2rem;
    padding: 1.5rem 1rem 1.25rem 1rem;
    margin-left: -1rem;
    margin-right: -1rem;
    border-top: 2px solid var(--section-border, var(--section-color));
    background-color: var(--secondary-system-background);
  }

  :global(.section-colored) :global(h2) {
    color: var(--section-color);
  }

  :global(.section-colored) :global(a:hover),
  :global(.section-colored) :global(a:focus-visible) {
    color: var(--section-hover);
  }

  main :global(h2) {
    color: var(--label);
    margin: 0 0 1rem 0;
    font-weight: 600;
    font-size: 1.375rem;
    letter-spacing: -0.01em;
  }

  main :global(h2 + p) {
    color: var(--secondary-label);
    margin-bottom: 1rem;
    font-size: 0.9rem;
    margin-top: -0.5rem;
  }

  main :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  main :global(li) {
    margin-bottom: 0.5rem;
  }

  main :global(a) {
    font-size: 0.9375rem;
  }

  main :global(.project-desc) {
    margin: 0.15rem 0 0 0;
    font-size: 0.82rem;
    color: var(--secondary-label);
    line-height: 1.5;
  }

  .recent-posts {
    list-style: none;
    padding: 0;
    margin: 0 0 0.5rem 0;
  }

  .recent-posts li {
    margin-bottom: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--secondary-label);
    margin-left: 0;
  }

  .all-posts {
    font-size: 0.8125rem;
    color: var(--secondary-label);
  }

  @media (prefers-reduced-motion: no-preference) {
    .recent-posts li {
      transition: transform 0.15s ease;
    }

    .recent-posts li:hover {
      transform: translateX(2px);
    }
  }

  @media (prefers-contrast: more) {
    :global(.section-colored) {
      border-top-width: 3px;
    }
  }
</style>
