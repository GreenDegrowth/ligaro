---
import Layout from "../layouts/Layout.astro";
import Particles from "../components/Particles.astro";
import { Content as IntroContent } from "../sections/intro.md";
import { Content as PersonalContent } from "../sections/personal.md";
import { Content as WritingContent } from "../sections/writing.md";
import { Content as OpenSourceContent } from "../sections/opensource.md";
import { Content as SupportContent } from "../sections/support.md";
---

<Layout
  title="Timothy Brits"
  description="Links and ways to connect with Timothy Brits - social profiles, and more."
  type="website"
>
  <Particles />
  <main aria-label="Content">
    <IntroContent />
    <PersonalContent />
    <OpenSourceContent />
    <WritingContent />
    <SupportContent />
  </main>
</Layout>

<style>
  main {
    margin: auto;
  }

  :global(h1) {
    text-align: center;
    color: var(--color-heading);
    margin: 0 0 0.5rem 0;
    font-weight: 500;
    font-size: 1.75rem;
  }

  :global(h1 + p) {
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  :global(.section-personal),
  :global(.section-writing),
  :global(.section-opensource),
  :global(.section-support) {
    margin-top: 2.5rem;
  }

  :global(h2) {
    text-align: left;
    color: var(--color-heading);
    margin: 0 0 0.75rem 0;
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  :global(h2 + p) {
    text-align: left;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    font-size: 0.9rem;
    margin-top: -0.5rem;
  }

  :global(ul) {
    list-style-type: none;
    padding: 0;
    margin-bottom: 0;
  }

  :global(li) {
    margin-bottom: 0.6rem;
  }

  :global(a) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-link);
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0 1.5px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    transition:
      color 0.2s ease,
      background-size 0.35s ease;
    font-size: 0.95rem;
  }

  :global(a:hover) {
    color: var(--color-link-hover);
    background-size: 100% 1.5px;
  }

  :global(a i) {
    font-size: 1.1em;
    flex: 0 0 auto;
  }

  :global(a span) {
    flex-grow: 1;
  }

  :global(.project-desc) {
    margin: 0.15rem 0 0 1.6rem;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  :global(h2::before) {
    content: "✦";
    margin-right: 0.4em;
    display: inline-block;
    animation: sway 4s ease-in-out infinite;
    color: var(--color-link);
    opacity: 0.7;
  }

  @keyframes sway {
    0%,
    100% {
      transform: rotate(-8deg);
    }
    50% {
      transform: rotate(8deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(h2::before) {
      animation: none;
    }
  }
</style>
