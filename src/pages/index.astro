---
import Layout from "../layouts/Layout.astro";
import { Content as IntroContent } from "../sections/intro.md";
import { Content as PersonalContent } from "../sections/personal.md";
import { Content as WritingContent } from "../sections/writing.md";
import { Content as OpenSourceContent } from "../sections/opensource.md";
import { Content as SupportContent } from "../sections/support.md";
import { formatDate, getBlogPosts, getPostSlug } from "../lib/blog";

const posts = await getBlogPosts();
const recentPosts = posts.slice(0, 5);
---

<Layout
  title="Timothy Brits"
  description="Links and ways to connect with Timothy Brits - social profiles, and more."
  type="website"
>
  <main id="main-content" tabindex="-1">
    <h1 class="visually-hidden">Timothy Brits</h1>
    <IntroContent />
    {
      recentPosts.length > 0 && (
        <section
          class="section-colored"
          style="--section-color: var(--moss); --section-border: var(--moss); --section-hover: var(--moss-hover);"
        >
          <p class="section-kicker" aria-hidden="true">
            I.
          </p>
          <h2>Blog</h2>
          <ul class="recent-posts">
            {recentPosts.map((post) => (
              <li>
                <a href={`/blog/${getPostSlug(post.id)}`}>{post.data.title}</a>
                <time
                  class="post-date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {formatDate(post.data.pubDate)}
                </time>
              </li>
            ))}
          </ul>
          <a href="/blog" class="all-posts">
            All posts <span aria-hidden="true">&rarr;</span>
          </a>
        </section>
      )
    }
    <OpenSourceContent />
    <WritingContent />
    <SupportContent />
    <PersonalContent />
  </main>
</Layout>

<style>
  main {
    margin: auto;
  }

  :global(main > p:first-child) {
    color: var(--ink);
    margin-bottom: 3rem;
    font-size: 1.3125rem;
    font-weight: 400;
    font-style: italic;
    line-height: 1.5;
    letter-spacing: 0;
    text-wrap: balance;
  }

  :global(.section-colored) {
    margin-top: 3.5rem;
  }

  :global(.section-colored) :global(.section-kicker) {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: 0.02em;
    color: var(--section-color);
    margin: 0 0 0.25rem 0;
  }

  :global(.section-colored) :global(h2) {
    color: var(--ink);
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.625rem;
    letter-spacing: -0.01em;
    margin: 0 0 0.25rem 0;
  }

  :global(.section-colored) :global(h2)::after {
    content: "";
    display: block;
    width: 40px;
    height: 1px;
    background: var(--section-border);
    margin-top: 0.75rem;
  }

  :global(.section-colored) :global(h2) + :global(p) {
    color: var(--ink-soft);
    margin-top: 1rem;
    margin-bottom: 0;
    font-size: 1rem;
  }

  :global(.section-colored) :global(a:hover),
  :global(.section-colored) :global(a:focus-visible) {
    color: var(--section-hover);
    text-decoration-color: var(--section-hover);
  }

  main :global(ul) {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0 0;
  }

  main :global(li) {
    margin-bottom: 0.5rem;
  }

  main :global(a) {
    font-size: 1.0625rem;
  }

  main :global(.project-desc) {
    margin: 0.1rem 0 0 0;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .recent-posts {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1rem 0;
  }

  .recent-posts li {
    margin-bottom: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .post-date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .all-posts {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--section-color);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .all-posts:hover {
    color: var(--section-hover);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .recent-posts li {
      transition: transform 0.15s ease;
    }

    .recent-posts li:hover {
      transform: translateX(2px);
    }
  }

  @media (prefers-contrast: more) {
    :global(.section-colored) :global(h2)::after {
      height: 2px;
    }
  }
</style>
