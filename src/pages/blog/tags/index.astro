---
import Layout from "../../../layouts/Layout.astro";
import {
  getAllTags,
  getBlogPosts,
  getPostsByTag,
} from "../../../lib/blog";

const posts = await getBlogPosts();
const tags = getAllTags(posts);
const tagsWithCount = tags.map((tag) => ({
  tag,
  count: getPostsByTag(posts, tag).length,
}));
---

<Layout
  title="Tags — Timothy Brits"
  description="Browse blog posts by tag."
  type="website"
>
  <main id="main-content" tabindex="-1">
    <a href="/blog" class="nav-link back-link">
      <span aria-hidden="true">&larr;</span> All posts
    </a>
    <h1 class="page-title">Tags</h1>
    {
      tagsWithCount.length === 0 ? (
        <p class="empty">No tags yet.</p>
      ) : (
        <ul class="tag-list">
          {tagsWithCount.map(({ tag, count }) => (
            <li>
              <a href={`/blog/tags/${tag}`} class="tag">
                {tag}
              </a>
              <span class="count">{count}</span>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding-top: 2rem;
  }

  .back-link {
    margin-bottom: 2rem;
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .tag-list li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .count {
    font-family: var(--font-sans), system-ui, sans-serif;
    font-size: 0.7rem;
    color: var(--ink-soft);
    letter-spacing: 0.05em;
  }
</style>
